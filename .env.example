# Required for Postgres mode and the bootstrap/import scripts.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/learning_optimizer

# Optional override for the local JSON store directory and import source.
LEARNING_OPTIMIZER_DATA_DIR=.data

# Optional Gemini-backed semantic ingestion.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
